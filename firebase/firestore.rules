rules_version = '2';

// Reglas para el dashboard (Firebase Client SDK + Auth).
// El bot Vicky usa Firebase Admin SDK y NO pasa por estas reglas.
//
// Requisito: solo usuarios con sesión Firebase Auth (login del panel).
// Para endurecer: añadí custom claims (ej. admin) y comprobá request.auth.token.admin == true.

service cloud.firestore {
  match /databases/{database}/documents {

    match /config/{docId} {
      allow read, write: if request.auth != null;
      match /versiones/{verId} {
        allow read, write: if request.auth != null;
      }
      match /borradores/{borradorId} {
        allow read, write: if request.auth != null;
      }
    }

    match /mensajes_programados/{progId} {
      allow read, write: if request.auth != null;
    }

    match /entregas_agenda/{id} {
      allow read, write: if request.auth != null;
    }

    match /lid_mapeo/{lidId} {
      allow read, write: if request.auth != null;
    }

    match /datos_entrega_cliente/{id} {
      allow read, write: if request.auth != null;
    }

    match /servicios/{docId} {
      allow read, write: if request.auth != null;
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      match /mensajes/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    match /clientes/{tel} {
      allow read, write: if request.auth != null;
    }

    match /colaLena/{pedidoId} {
      allow read, write: if request.auth != null;
    }

    match /rutas_logistica/{rutaId} {
      allow read, write: if request.auth != null;
    }

    match /mensajes_log/{logId} {
      allow read, write: if request.auth != null;
    }

    match /usuarios/{uid} {
      allow read, write: if request.auth != null;
    }
  }
}
